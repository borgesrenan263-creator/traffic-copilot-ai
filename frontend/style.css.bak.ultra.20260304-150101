:root{
  --bg0:#0a0f1f;
  --bg1:#0f1730;
  --card: rgba(255,255,255,.06);
  --card2: rgba(255,255,255,.09);
  --stroke: rgba(255,255,255,.12);
  --text:#e9eefc;
  --muted: rgba(233,238,252,.72);
  --blue:#2b6cff;
  --blue2:#1f4fd6;
  --danger:#ff3b30;
  --shadow: 0 14px 40px rgba(0,0,0,.35);
  --radius: 22px;
}

[data-theme="light"]{
  --bg0:#f4f7ff;
  --bg1:#ffffff;
  --card: rgba(0,0,0,.05);
  --card2: rgba(0,0,0,.08);
  --stroke: rgba(0,0,0,.12);
  --text:#0d1222;
  --muted: rgba(13,18,34,.68);
  --shadow: 0 12px 34px rgba(17,24,39,.12);
}

*{ box-sizing:border-box; }
html,body{ height:100%; margin:0; font-family: system-ui,-apple-system,Segoe UI,Roboto,Ubuntu,"Helvetica Neue",Arial; color:var(--text); }
body{
  background: radial-gradient(1200px 600px at 20% 0%, rgba(83,118,255,.25), transparent 55%),
              radial-gradient(900px 500px at 85% 20%, rgba(255,61,173,.18), transparent 60%),
              linear-gradient(180deg, var(--bg0), var(--bg1));
}

#app{ max-width: 980px; margin: 0 auto; padding: 18px 14px 28px; }

.topbar{
  display:flex; align-items:center; justify-content:space-between;
  gap:12px; margin-bottom: 14px;
}
h1{ margin:0; font-size: 44px; letter-spacing:.2px; }
.badge{
  display:inline-flex; padding:10px 14px; border-radius: 999px;
  background: var(--card); border:1px solid var(--stroke);
  color: var(--muted); margin-top:10px;
}

.topActions{ display:flex; gap:10px; align-items:center; }
.iconBtn{
  width:48px; height:48px; border-radius: 16px;
  background: var(--card); border:1px solid var(--stroke);
  color: var(--text); font-size:18px;
}
.panicBtn{
  height:48px; padding: 0 16px; border-radius: 16px;
  background: rgba(255,59,48,.12);
  border: 1px solid rgba(255,59,48,.35);
  color: var(--text);
}

.mapCard{
  background: var(--card);
  border: 1px solid var(--stroke);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow:hidden;
  margin-bottom: 14px;
}
#map{
  width:100%;
  height: 360px;
}

/* Leaflet stacking fix */
.leaflet-container{ z-index: 1; }
.mapCard{ position:relative; z-index:1; }

.panel{
  background: var(--card);
  border: 1px solid var(--stroke);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 14px;
}

.btnGrid{
  display:grid; grid-template-columns: 1fr 1fr 1fr;
  gap:10px;
}

button{
  border: 1px solid var(--stroke);
  border-radius: 999px;
  background: var(--card2);
  color: var(--text);
  padding: 14px 14px;
  font-size: 16px;
}
button:active{ transform: scale(.99); }

.primary{ background: linear-gradient(180deg, var(--blue), var(--blue2)); border-color: rgba(255,255,255,.10); }
.secondary{ background: rgba(43,108,255,.14); }
.ghost{ background: transparent; }

.coords{ margin-top: 12px; color: var(--muted); }
.chips{ display:flex; gap:10px; flex-wrap:wrap; margin-top: 12px; }
.chip{
  padding: 10px 12px; border-radius: 999px;
  background: rgba(0,0,0,.10);
  border: 1px solid var(--stroke);
  color: var(--muted);
}

.toggles{ display:flex; gap:14px; flex-wrap:wrap; margin-top: 12px; }
.toggle{ display:flex; gap:8px; align-items:center; color: var(--muted); }

.chatLog{
  margin-top: 12px;
  padding: 12px;
  border-radius: 16px;
  border: 1px solid var(--stroke);
  background: rgba(0,0,0,.12);
  min-height: 120px;
  max-height: 220px;
  overflow:auto;
  color: var(--muted);
  white-space: pre-line;
}

.inputRow{
  display:flex; gap: 10px; margin-top: 12px;
}
#question{
  flex:1;
  border-radius: 18px;
  border:1px solid var(--stroke);
  background: rgba(0,0,0,.10);
  color: var(--text);
  padding: 14px 14px;
  font-size: 16px;
}
.sendBtn{
  width: 120px;
  background: linear-gradient(180deg, var(--blue), var(--blue2));
  border-color: rgba(255,255,255,.10);
}

.hint{ margin-top: 10px; color: var(--muted); font-size: 14px; }

@media (max-width: 520px){
  h1{ font-size: 40px; }
  #map{ height: 320px; }
  .btnGrid{ grid-template-columns: 1fr; }
  .sendBtn{ width: 110px; }
}
