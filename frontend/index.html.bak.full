<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Traffic Copilot AI</title>

  <!-- Leaflet (CDN) -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script defer src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <link rel="stylesheet" href="/style.css" />
</head>

<body>
  <div id="app">
    <header class="topbar">
      <div class="brand">
        <h1>Traffic Copilot AI</h1>
        <div class="badge">MVP • Driver Mode</div>
      </div>

      <div class="topActions">
        <button id="btnTheme" class="iconBtn" title="Alternar tema">🌓</button>
        <button id="btnPanic" class="panicBtn" title="Emergência">🚨 PANIC</button>
      </div>
    </header>

    <main class="layout">
      <section class="mapCard">
        <div id="map" class="map"></div>
      </section>

      <section class="panelCard">
        <div class="actions">
          <button id="btnLoc" class="btn primary">📍 Minha localização</button>
          <button id="btnDest" class="btn">🎯 Definir destino</button>
          <button id="btnClear" class="btn ghost">🧹 Limpar</button>
        </div>

        <div class="coords">
          <div>Origem: <span id="originText">—</span></div>
          <div>Destino: <span id="destText">—</span></div>
        </div>

        <div class="chips">
          <div class="chip" id="chipMain">Rota principal: —</div>
          <div class="chip" id="chipAlt">Alternativa: —</div>
          <div class="chip" id="chipTraffic">Trânsito: —</div>
        </div>

        <div id="chatLog" class="chatLog" aria-live="polite"></div>

        <div class="inputRow">
          <input id="question" placeholder="Pergunte: Como está o trânsito?" />
          <button id="btnSend" class="btn send">Enviar</button>
        </div>

        <div class="hint">
          Dica: toque no mapa para escolher destino quando estiver no modo 🎯.
        </div>
      </section>
    </main>
  </div>

  <script type="module" src="./main.js"></script>
</body>
</html>
