:root{
  --bg: #0b1220;
  --panel: rgba(16, 24, 40, .70);
  --card: rgba(255,255,255,.06);
  --text: rgba(255,255,255,.92);
  --muted: rgba(255,255,255,.70);
  --line: rgba(255,255,255,.10);
  --primary: #2d6cff;
  --primary2: #1d4ed8;
  --danger: #ff3b30;

  --radius: 22px;
  --shadow: 0 18px 50px rgba(0,0,0,.35);
}

[data-theme="light"]{
  --bg: #f6f7fb;
  --panel: rgba(255,255,255,.72);
  --card: rgba(0,0,0,.04);
  --text: rgba(0,0,0,.86);
  --muted: rgba(0,0,0,.62);
  --line: rgba(0,0,0,.10);
  --primary: #2563eb;
  --primary2: #1d4ed8;
  --danger: #dc2626;
  --shadow: 0 18px 50px rgba(0,0,0,.10);
}

*{ box-sizing: border-box; }
html,body{ height:100%; margin:0; }
body{
  font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
  background: radial-gradient(1200px 600px at 10% 0%, rgba(45,108,255,.25), transparent 60%),
              radial-gradient(900px 500px at 90% 10%, rgba(255,59,48,.16), transparent 55%),
              var(--bg);
  color: var(--text);
}

#app{
  max-width: 980px;
  margin: 0 auto;
  padding: 18px 14px 24px;
}

.topbar{
  display:flex;
  align-items:flex-end;
  justify-content:space-between;
  gap: 12px;
  margin-bottom: 14px;
}
.brand h1{
  margin:0;
  font-weight: 800;
  letter-spacing: .4px;
  font-size: clamp(34px, 5vw, 52px);
  line-height: 1.05;
}
.badge{
  display:inline-flex;
  margin-top: 10px;
  padding: 10px 14px;
  border-radius: 999px;
  background: var(--card);
  border: 1px solid var(--line);
  color: var(--muted);
  backdrop-filter: blur(10px);
}

.topActions{
  display:flex;
  gap: 10px;
  align-items:center;
}

.iconBtn{
  height: 44px;
  width: 44px;
  border-radius: 14px;
  border: 1px solid var(--line);
  background: var(--panel);
  color: var(--text);
  box-shadow: var(--shadow);
  backdrop-filter: blur(10px);
}

.panicBtn{
  height: 44px;
  padding: 0 14px;
  border-radius: 14px;
  border: 1px solid rgba(255,59,48,.35);
  background: linear-gradient(180deg, rgba(255,59,48,.20), rgba(255,59,48,.12));
  color: var(--text);
  box-shadow: var(--shadow);
}

.layout{
  display:grid;
  grid-template-columns: 1fr;
  gap: 14px;
}

.mapCard, .panelCard{
  border-radius: var(--radius);
  background: var(--panel);
  border: 1px solid var(--line);
  box-shadow: var(--shadow);
  overflow: hidden;
  backdrop-filter: blur(12px);
}

.map{
  width:100%;
  height: 46vh;
  min-height: 320px;
  max-height: 520px;
}

.panelCard{
  padding: 14px;
}

.actions{
  display:grid;
  grid-template-columns: 1fr;
  gap: 10px;
}

.btn{
  height: 54px;
  border-radius: 999px;
  border: 1px solid var(--line);
  background: var(--card);
  color: var(--text);
  font-weight: 700;
  letter-spacing: .2px;
}
.btn.primary{
  background: linear-gradient(180deg, var(--primary), var(--primary2));
  border: 1px solid rgba(255,255,255,.16);
}
.btn.ghost{
  background: transparent;
}
.btn.send{
  width: 110px;
  background: linear-gradient(180deg, var(--primary), var(--primary2));
  border: 1px solid rgba(255,255,255,.16);
}

.coords{
  margin: 12px 2px 6px;
  color: var(--muted);
  font-size: 14px;
  line-height: 1.5;
}

.chips{
  display:flex;
  flex-wrap:wrap;
  gap: 8px;
  margin: 8px 0 10px;
}
.chip{
  padding: 8px 10px;
  border-radius: 999px;
  background: var(--card);
  border: 1px solid var(--line);
  color: var(--muted);
  font-size: 13px;
}

.chatLog{
  height: 150px;
  overflow:auto;
  border-radius: 16px;
  border: 1px solid var(--line);
  background: rgba(0,0,0,.10);
  padding: 10px;
  color: var(--muted);
  font-size: 14px;
  line-height: 1.35;
}
[data-theme="light"] .chatLog{
  background: rgba(0,0,0,.03);
}

.inputRow{
  display:flex;
  gap: 10px;
  margin-top: 10px;
}
.inputRow input{
  flex: 1;
  height: 54px;
  border-radius: 16px;
  border: 1px solid var(--line);
  background: rgba(0,0,0,.10);
  color: var(--text);
  padding: 0 14px;
  outline: none;
}
[data-theme="light"] .inputRow input{
  background: rgba(0,0,0,.03);
}

.hint{
  margin-top: 10px;
  color: var(--muted);
  font-size: 12px;
}

/* Mobile polish */
@media (min-width: 860px){
  .layout{
    grid-template-columns: 1.2fr .8fr;
    align-items: start;
  }
  .map{ height: 70vh; min-height: 520px; }
}

/* Leaflet inside rounded card */
.leaflet-container{
  background: rgba(0,0,0,.06);
}

/* === CLICK FIX (mobile) === */
.topbar, .panelCard, .actions, .btn, .iconBtn, .panicBtn, .inputRow {
  position: relative;
  z-index: 50;
  pointer-events: auto;
}

.mapCard, #map, .leaflet-container {
  position: relative;
  z-index: 1;
}

