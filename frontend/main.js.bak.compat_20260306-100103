import L from "leaflet"

let map
let origin = null
let destination = null
let routeLine = null

// ===============================
// STATUS LOG
// ===============================

function setStatus(msg) {

  const log = document.getElementById("statusLog")

  if (!log) return

  const time = new Date().toLocaleTimeString()

  log.innerHTML =
    `[${time}] ${msg}<br>` + log.innerHTML

}

// ===============================
// MAP INIT
// ===============================

function initMap() {

  map = L.map("map").setView([-20.8487, -49.3522], 13)

  // EXPOSE MAP FOR VOICE (up_voice.js)
  try { window.map = map } catch(e) {}
  try { window.L = window.L || L } catch(e) {}

  L.tileLayer(
    "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",
    {
      attribution:
        "© OpenStreetMap contributors",
    }
  ).addTo(map)

  map.on("click", (e) => {

    if (!destination) {
      setDestination(e.latlng.lat, e.latlng.lng)
    }

  })

  setStatus("🗺 mapa carregado")

}

// ===============================
// GEOLOCATION
// ===============================

function setMyLocation() {

  navigator.geolocation.getCurrentPosition(
    (pos) => {

      const lat = pos.coords.latitude
      const lon = pos.coords.longitude

      origin = { lat, lon }

      setStatus(
        `📍 Origem definida: ${lat.toFixed(
          5
        )},${lon.toFixed(5)}`
      )

      map.setView([lat, lon], 15)

    },
    () => {
      setStatus("❌ GPS falhou")
    }
  )
}

// ===============================
// DESTINATION
// ===============================

function setDestination(lat, lon) {

  destination = { lat, lon }

  setStatus(
    `🎯 Destino definido: ${lat.toFixed(
      5
    )},${lon.toFixed(5)}`
  )

  if (origin) {
    calculateRoute()
  }
}

// ===============================
// OSRM ROUTE
// ===============================

async function calculateRoute() {

  const url =
    `https://router.project-osrm.org/route/v1/driving/` +
    `${origin.lon},${origin.lat};${destination.lon},${destination.lat}` +
    `?overview=full&geometries=geojson`

  const res = await fetch(url)

  const data = await res.json()

  const route = data.routes[0]

  drawRoute(route.geometry)

  const km = (route.distance / 1000).toFixed(1)
  const min = Math.round(route.duration / 60)

  setStatus(
    `🚗 Rota principal: ${km} km • ${min} min`
  )
}

// ===============================
// DRAW ROUTE
// ===============================

function drawRoute(geo) {

  if (routeLine) map.removeLayer(routeLine)

  routeLine = L.geoJSON(geo, {
    style: {
      color: "#2b7cff",
      weight: 6,
    },
  }).addTo(map)

}

// ===============================
// CLEAR
// ===============================

function clearRoute() {

  origin = null
  destination = null

  if (routeLine) {
    map.removeLayer(routeLine)
    routeLine = null
  }

  setStatus("🧹 rota limpa")

}

// ===============================
// PANIC
// ===============================

function triggerPanic() {

  setStatus("🚨 PANIC MODE ATIVADO")

  alert(
    "🚨 Emergência!\nSua localização pode ser enviada."
  )

}

