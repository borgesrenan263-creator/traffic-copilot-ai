<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Traffic Copilot AI</title>

    <!-- Leaflet CSS -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""
    />
    <link rel="stylesheet" href="/style.css" />
  </head>

  <body>
    <div class="app">
      <header class="top">
        <div class="brand">
          <div class="title">Traffic Copilot AI</div>
          <div class="sub">MVP • Driver Mode</div>
        </div>

        <div class="topActions">
          <button id="btnTheme" class="pill" type="button">🌙</button>
          <button id="btnPanic" class="pill danger" type="button">🚨 PANIC</button>
        </div>
      </header>

      <section class="card mapCard">
        <div id="map" class="map"></div>
        <div id="mapStatus" class="mapStatus">Carregando...</div>
      </section>

      <section class="card panel">
        <div class="rowBtns">
          <button id="btnLocation" class="primary" type="button">📍 Minha localização</button>
          <button id="destBtn" class="secondary" type="button">🎯 Definir destino</button>
          <button id="btnDriver" class="secondary" type="button">🚗 Driver Mode: OFF</button>
        </div>

        <div class="rowBtns">
          <button id="btnClear" class="ghost" type="button">🧹 Limpar</button>
        </div>

        <div class="kv">
          <div><span>Origem</span><b id="originTxt">—</b></div>
          <div><span>Destino</span><b id="destTxt">—</b></div>
        </div>

        <div class="chips">
          <div class="chip"><span>Rota principal:</span> <b id="routeTxt">—</b></div>
          <div class="chip"><span>Alternativa:</span> <b id="altTxt">—</b></div>
        </div>

        <div class="chips">
          <div class="chip"><span>Trânsito:</span> <b id="trafficTxt">—</b></div>
          <div class="chip"><span>Velocidade:</span> <b id="speedTxt">—</b></div>
        </div>

        <div class="status">
          <div class="statusTitle">Status</div>
          <pre id="log" class="log"></pre>
        </div>

        <div class="chat">
          <input id="q" class="q" placeholder="Pergunte: Como está o trânsito?" />
          <button id="sendBtn" class="send" type="button">Enviar</button>
        </div>

        <div class="hint">
          Dica: toque no mapa para escolher destino quando estiver no modo 🎯.
        </div>
      </section>
    </div>

    <!-- Leaflet JS -->
    <script
      src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
      crossorigin=""
    ></script>

    <!-- App -->
    <script type="module" src="/main.js"></script>

    <!-- Voice + Driver Mode -->
    <script src="./up_voice.js"></script>
    <script src="./driver_mode.js"></script>
  </body>
</html>
