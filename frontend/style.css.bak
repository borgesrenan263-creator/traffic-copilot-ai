/* Traffic Copilot AI — Premium UI (Light/Dark) */

:root {
  /* typography */
  --font: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
  --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;

  /* radius + spacing */
  --r-xl: 28px;
  --r-lg: 18px;
  --r-md: 14px;
  --r-sm: 12px;

  --shadow-1: 0 10px 30px rgba(0,0,0,.20);
  --shadow-2: 0 18px 60px rgba(0,0,0,.35);
  --stroke: rgba(255,255,255,.12);

  /* layout */
  --max: 980px;
  --gap: 14px;

  /* brand */
  --brand: 76 117 255; /* rgb */
  --brand2: 0 210 255; /* rgb */
  --good: 0 200 140;
  --warn: 255 184 0;
  --bad: 255 73 101;

  /* default = dark */
  --bg0: #070B12;
  --bg1: #0B1220;
  --card: rgba(14, 22, 36, .62);
  --card2: rgba(14, 22, 36, .78);
  --text: rgba(255,255,255,.92);
  --muted: rgba(255,255,255,.66);
  --muted2: rgba(255,255,255,.50);

  --btn: rgba(76,117,255,.24);
  --btn2: rgba(76,117,255,.34);
  --btnStroke: rgba(120,160,255,.28);

  --input: rgba(255,255,255,.08);
  --inputStroke: rgba(255,255,255,.16);

  --mapStroke: rgba(255,255,255,.08);
  --mapBg: rgba(255,255,255,.04);
}

html[data-theme="light"]{
  --bg0: #F6F7FB;
  --bg1: #EFF2FA;
  --card: rgba(255,255,255,.76);
  --card2: rgba(255,255,255,.92);
  --text: rgba(12,18,30,.92);
  --muted: rgba(12,18,30,.62);
  --muted2: rgba(12,18,30,.50);

  --shadow-1: 0 10px 30px rgba(10,20,40,.10);
  --shadow-2: 0 18px 60px rgba(10,20,40,.14);
  --stroke: rgba(10,20,40,.10);

  --btn: rgba(76,117,255,.12);
  --btn2: rgba(76,117,255,.18);
  --btnStroke: rgba(76,117,255,.22);

  --input: rgba(10,20,40,.06);
  --inputStroke: rgba(10,20,40,.12);

  --mapStroke: rgba(10,20,40,.08);
  --mapBg: rgba(10,20,40,.03);
}

*{ box-sizing: border-box; }
html, body { height: 100%; }
body{
  margin: 0;
  font-family: var(--font);
  color: var(--text);
  background:
    radial-gradient(1200px 800px at 25% -10%, rgba(var(--brand), .28), transparent 55%),
    radial-gradient(900px 700px at 95% 10%, rgba(var(--brand2), .22), transparent 55%),
    linear-gradient(180deg, var(--bg0), var(--bg1));
  overflow-x: hidden;
}

a{ color: inherit; text-decoration: none; }
button, input{ font: inherit; color: inherit; }

#app{
  max-width: var(--max);
  margin: 0 auto;
  padding: 22px 14px 24px;
  display: flex;
  flex-direction: column;
  gap: var(--gap);
}

/* header */
.header{
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

h1{
  margin: 0;
  letter-spacing: -0.04em;
  font-weight: 800;
  font-size: clamp(34px, 7vw, 64px);
  line-height: 1.02;
}

.badge{
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-radius: 999px;
  background: rgba(255,255,255,.06);
  border: 1px solid var(--stroke);
  color: var(--muted);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  width: fit-content;
  margin-top: 10px;
}

.themeToggle{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 999px;
  border: 1px solid var(--stroke);
  background: rgba(255,255,255,.06);
  color: var(--muted);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  cursor: pointer;
  transition: transform .12s ease, background .2s ease, border-color .2s ease;
  user-select: none;
}
.themeToggle:active{ transform: scale(.98); }
.themeToggle:hover{ background: rgba(255,255,255,.10); border-color: rgba(255,255,255,.18); }
.themeToggle .dot{
  width: 10px; height: 10px; border-radius: 50%;
  background: rgb(var(--brand));
  box-shadow: 0 0 18px rgba(var(--brand), .55);
}

/* map container */
#map{
  width: 100%;
  height: min(54vh, 520px);
  border-radius: var(--r-xl);
  overflow: hidden;
  border: 1px solid var(--mapStroke);
  background: var(--mapBg);
  box-shadow: var(--shadow-1);
}

/* panel */
.panel{
  border-radius: var(--r-xl);
  border: 1px solid var(--stroke);
  background: linear-gradient(180deg, var(--card), var(--card2));
  box-shadow: var(--shadow-2);
  padding: 14px;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

.row{
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12px;
}

.btn{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 16px 14px;
  width: 100%;
  border-radius: 999px;
  border: 1px solid var(--btnStroke);
  background: linear-gradient(180deg, var(--btn), rgba(255,255,255,.04));
  box-shadow: 0 12px 35px rgba(0,0,0,.18);
  cursor: pointer;
  transition: transform .12s ease, filter .2s ease, background .2s ease, border-color .2s ease;
  user-select: none;
}
.btn:hover{
  filter: brightness(1.08);
  border-color: rgba(var(--brand), .45);
  background: linear-gradient(180deg, var(--btn2), rgba(255,255,255,.06));
}
.btn:active{ transform: scale(.985); }
.btn:disabled{
  opacity: .55;
  cursor: not-allowed;
  filter: none;
}

.btn.primary{
  background: linear-gradient(180deg, rgba(var(--brand), .60), rgba(var(--brand), .30));
  border-color: rgba(var(--brand), .45);
  box-shadow: 0 16px 40px rgba(var(--brand), .22);
}
.btn.danger{
  background: linear-gradient(180deg, rgba(var(--bad), .35), rgba(255,255,255,.05));
  border-color: rgba(var(--bad), .35);
}

.coords{
  margin-top: 10px;
  display: grid;
  grid-template-columns: 1fr;
  gap: 6px;
  color: var(--muted);
}

.coords strong{ color: var(--text); font-weight: 700; }
.coords .kv{
  display: flex;
  gap: 10px;
  align-items: baseline;
}
.coords .k{ min-width: 72px; color: var(--muted2); }
.coords .v{ font-family: var(--mono); font-size: 13px; color: var(--muted); }

/* log */
#chatLog{
  margin-top: 12px;
  border-radius: var(--r-lg);
  border: 1px solid var(--stroke);
  background: rgba(255,255,255,.05);
  padding: 12px;
  min-height: 74px;
  color: var(--muted);
  line-height: 1.35;
  white-space: pre-wrap;
}

/* input row */
.inputRow{
  margin-top: 12px;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 10px;
}
#question{
  width: 100%;
  padding: 14px 14px;
  border-radius: 16px;
  border: 1px solid var(--inputStroke);
  background: var(--input);
  outline: none;
  color: var(--text);
}
#question::placeholder{ color: var(--muted2); }
#question:focus{
  border-color: rgba(var(--brand), .35);
  box-shadow: 0 0 0 4px rgba(var(--brand), .14);
}

#btnSend{
  padding: 14px 18px;
  border-radius: 16px;
  border: 1px solid rgba(var(--brand), .35);
  background: linear-gradient(180deg, rgba(var(--brand), .55), rgba(var(--brand), .25));
  cursor: pointer;
  box-shadow: 0 16px 40px rgba(var(--brand), .18);
  transition: transform .12s ease, filter .2s ease;
}
#btnSend:hover{ filter: brightness(1.08); }
#btnSend:active{ transform: scale(.985); }

/* leaflet tuning */
.leaflet-container{
  font-family: var(--font);
}
.leaflet-control-zoom a{
  border-radius: 12px !important;
}
.leaflet-control-zoom{
  border-radius: 12px !important;
  overflow: hidden;
  box-shadow: 0 10px 24px rgba(0,0,0,.20) !important;
  border: 1px solid var(--stroke) !important;
}
.leaflet-control-attribution{
  background: rgba(0,0,0,.0) !important;
  color: var(--muted2) !important;
}

/* responsive */
@media (max-width: 720px){
  #app{ padding: 18px 12px 20px; }
  .row{ grid-template-columns: 1fr; }
  #map{ height: min(50vh, 460px); border-radius: 24px; }
  .panel{ border-radius: 24px; }
}

@media (prefers-reduced-motion: reduce){
  *{ transition: none !important; }
}

/* --- Leaflet container safety (mobile) --- */
#map{
  width: 100%;
  height: 46vh;
  min-height: 320px;
  border-radius: 22px;
  overflow: hidden;
}
.leaflet-container{
  background: #0b1220;
}
